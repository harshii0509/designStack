#!/usr/bin/env bash
# designStack setup — installs designStack skills into Claude Code
set -e

DESIGNSTACK_DIR="$HOME/.claude/skills/ds"
DESIGNSTACK_VER=$(cat "$DESIGNSTACK_DIR/VERSION" 2>/dev/null || echo "0.1.0")
_QUIET="no"
_PREFIX="namespaced"
_STATE_DIR="$HOME/.dstack"
_LEGACY_STATE_DIR="$HOME/.ds"

# ── Flag parsing ───────────────────────────────────────────────────────────────
for arg in "$@"; do
  [ "$arg" = "--quiet" ] || [ "$arg" = "-q" ] && _QUIET="yes"
  [ "$arg" = "--flat" ] && _PREFIX="flat"
done

log() { [ "$_QUIET" = "no" ] && echo "$@"; }

# ── OS check ──────────────────────────────────────────────────────────────────
_OS=$(uname -s 2>/dev/null || echo "unknown")
if [ "$_OS" != "Darwin" ] && [ "$_OS" != "Linux" ]; then
  echo "  designStack requires Mac or Linux."
  echo "  Windows support via WSL — see docs/windows.md for a step-by-step guide."
  echo ""
  exit 1
fi

log ""
log "  ██████╗ ███████╗████████╗ █████╗  ██████╗██╗  ██╗"
log "  ██╔══██╗██╔════╝╚══██╔══╝██╔══██╗██╔════╝██║ ██╔╝"
log "  ██║  ██║███████╗   ██║   ███████║██║     █████╔╝ "
log "  ██║  ██║╚════██║   ██║   ██╔══██║██║     ██╔═██╗ "
log "  ██████╔╝███████║   ██║   ██║  ██║╚██████╗██║  ██╗"
log "  ╚═════╝ ╚══════╝   ╚═╝   ╚═╝  ╚═╝ ╚═════╝╚═╝  ╚═╝"
log ""
log "  v$DESIGNSTACK_VER — Claude Code for designers"
log ""

# ── Check Claude Code is installed ────────────────────────────────────────────
if ! command -v claude >/dev/null 2>&1; then
  echo "  ✗ Claude Code not found."
  echo "    Install it from: https://claude.ai/download"
  echo ""
  exit 1
fi
log "  ✓ Claude Code found"

# ── One-time update-state migration ───────────────────────────────────────────
if [ -d "$_LEGACY_STATE_DIR" ]; then
  mkdir -p "$_STATE_DIR" 2>/dev/null || true
  for _name in config.yaml last-update-check just-upgraded-from update-snoozed; do
    if [ -f "$_LEGACY_STATE_DIR/$_name" ] && [ ! -f "$_STATE_DIR/$_name" ]; then
      cp "$_LEGACY_STATE_DIR/$_name" "$_STATE_DIR/$_name" 2>/dev/null || true
    fi
  done
fi

# ── Version migration ─────────────────────────────────────────────────────────
_INSTALLED_VER_FILE="$DESIGNSTACK_DIR/.installed-version"
_PREV_VER=""
[ -f "$_INSTALLED_VER_FILE" ] && _PREV_VER=$(cat "$_INSTALLED_VER_FILE")
echo "$DESIGNSTACK_VER" > "$_INSTALLED_VER_FILE"
if [ -n "$_PREV_VER" ] && [ "$_PREV_VER" != "$DESIGNSTACK_VER" ]; then
  log "  ✓ Upgraded from v$_PREV_VER → v$DESIGNSTACK_VER"
fi

# ── Check for browse binary (optional, enables visual features) ───────────────
if [ -x "$HOME/.claude/skills/ds/browse/dist/browse" ] || [ -x "$HOME/.claude/skills/gstack/browse/dist/browse" ]; then
  log "  ✓ Browse found — visual features enabled"
else
  log "  ⚠  Browse not found — /ds-look, /ds-mobile, /ds-a11y, and /ds-unstuck will describe"
  log "     issues in plain English instead of showing screenshots."
  log "     Install the browse binary (designStack or gstack) for screenshots."
fi

# ── Telemetry consent ─────────────────────────────────────────────────────────
_TEL_FILE="$HOME/.dstack/config"
mkdir -p "$HOME/.dstack/analytics" 2>/dev/null || true

if [ ! -f "$_TEL_FILE" ]; then
  if [ "$_QUIET" = "no" ]; then
    echo ""
    echo "  designStack can send anonymous usage data to help improve the tool."
    echo "  Data sent: which skills you run and whether they succeed."
    echo "  No code, file paths, or personal data. Never sold or shared."
    echo ""
    echo "  A) Share usage data (recommended) — helps us improve, anonymous device ID"
    echo "  B) Anonymous only — aggregate counts, no device ID"
    echo "  C) Off — keep everything on this machine"
    echo ""
    printf "  Analytics? [A/b/c]: "
    read -r _TEL_CHOICE </dev/tty || _TEL_CHOICE="a"
    case "$_TEL_CHOICE" in
      [bB]*) echo "telemetry=anonymous" > "$_TEL_FILE"
             log "  ✓ Analytics: anonymous" ;;
      [cC]*) echo "telemetry=off"       > "$_TEL_FILE"
             log "  ✓ Analytics: off" ;;
          *) echo "telemetry=community" > "$_TEL_FILE"
             log "  ✓ Analytics: on (community — anonymous device ID)" ;;
    esac
  else
    # Non-interactive / --quiet: default to community
    echo "telemetry=community" > "$_TEL_FILE"
  fi
else
  _CURRENT=$(grep "^telemetry=" "$_TEL_FILE" 2>/dev/null | cut -d= -f2 || echo "community")
  # Migrate legacy "on" → "community"
  if [ "$_CURRENT" = "on" ]; then
    sed -i.bak 's/^telemetry=on$/telemetry=community/' "$_TEL_FILE" 2>/dev/null || true
    _CURRENT="community"
  fi
  log "  ✓ Analytics: $_CURRENT (edit ~/.dstack/config to change)"
fi

# ── Hyphen aliases: create canonical /ds-* commands ──────────────────────────
_SKILLS_DIR="$HOME/.claude/skills"
for skill in start context unstuck look mobile a11y save share vibe brand polish animate delight stats upgrade; do
  _TARGET="$DESIGNSTACK_DIR/$skill/SKILL.md"
  _LINK_DIR="$_SKILLS_DIR/ds-$skill"
  if [ -f "$_TARGET" ]; then
    mkdir -p "$_LINK_DIR"
    ln -sf "$_TARGET" "$_LINK_DIR/SKILL.md" 2>/dev/null || true
  fi
done
mkdir -p "$_SKILLS_DIR/ds-update"
ln -sf "$DESIGNSTACK_DIR/upgrade/SKILL.md" "$_SKILLS_DIR/ds-update/SKILL.md" 2>/dev/null || true
log "  ✓ Hyphen commands installed — /ds-start, /ds-look, /ds-save, and more"

# ── Flat mode: create symlinks without /ds- prefix ───────────────────────────
if [ "$_PREFIX" = "flat" ]; then
  for skill in start context unstuck look mobile a11y save share vibe brand polish animate delight stats upgrade; do
    _TARGET="$DESIGNSTACK_DIR/$skill/SKILL.md"
    _LINK_DIR="$_SKILLS_DIR/$skill"
    if [ -f "$_TARGET" ]; then
      mkdir -p "$_LINK_DIR"
      ln -sf "$_TARGET" "$_LINK_DIR/SKILL.md" 2>/dev/null || true
    fi
  done
  mkdir -p "$_SKILLS_DIR/update"
  ln -sf "$DESIGNSTACK_DIR/upgrade/SKILL.md" "$_SKILLS_DIR/update/SKILL.md" 2>/dev/null || true
  log "  ✓ Flat mode: skills available as /start, /context, /unstuck, and more"
fi

# ── Add designStack to global CLAUDE.md ────────────────────────────────────────────
GLOBAL_CLAUDE="$HOME/.claude/CLAUDE.md"

if [ -f "$GLOBAL_CLAUDE" ] && grep -Eq "ds-start|ds:start" "$GLOBAL_CLAUDE" 2>/dev/null; then
  log "  ✓ designStack already in global CLAUDE.md"
else
  cat >> "$GLOBAL_CLAUDE" << 'EOF'

# designStack
- **designStack** is installed. Use designStack skills for design rules, visual QA, accessibility, and error recovery.
- `/ds-start` — First session wizard. Run this once per project.
- `/ds-context` — Refresh your Design Bible when your brand changes.
- `/ds-unstuck` — Something broke. Get a plain-English diagnosis.
- `/ds-look` — Does it look right? Visual check against your brand rules.
- `/ds-mobile` — Check it on phone, tablet, and desktop.
- `/ds-a11y` — Accessibility grade A–D with every problem marked.
- `/ds-save` — Save your progress with a human-readable description.
- `/ds-share` — Deploy and get a shareable link.
- `/ds-upgrade` or `/ds-update` — Pull the latest designStack and refresh install.
EOF
  log "  ✓ Added designStack to global CLAUDE.md"
fi

# ── Make bin and lib scripts executable ──────────────────────────────────────
chmod +x "$DESIGNSTACK_DIR/bin/"* 2>/dev/null || true
chmod +x "$DESIGNSTACK_DIR/lib/"*.sh 2>/dev/null || true

# ── Done ──────────────────────────────────────────────────────────────────────
log ""
log "  ┌─────────────────────────────────────────────────────────────┐"
log "  │  designStack v$DESIGNSTACK_VER installed!                                    │"
log "  │                                                             │"
log "  │  Open Claude Code and type:                                 │"
log "  │                                                             │"
log "  │    /ds-start                                            │"
log "  │                                                             │"
log "  │  That's it. The wizard takes 5 minutes and sets everything  │"
log "  │  up. Every other skill works automatically after that.      │"
log "  │                                                             │"
log "  │  All commands:                                              │"
log "  │    /ds-start     First-session setup wizard             │"
log "  │    /ds-context   Refresh your Design Bible              │"
log "  │    /ds-unstuck   Debug broken things                    │"
log "  │    /ds-look      Visual check against brand rules       │"
log "  │    /ds-mobile    Phone + tablet + desktop side-by-side  │"
log "  │    /ds-a11y      Accessibility grade with problem map   │"
log "  │    /ds-save      Save progress with a description       │"
log "  │    /ds-share     Deploy and get a shareable link        │"
log "  │    /ds-upgrade   Update designStack to latest release   │"
log "  │                                                             │"
log "  │  Questions? https://github.com/harshii0509/designStack/discussions │"
log "  └─────────────────────────────────────────────────────────────┘"
log ""
