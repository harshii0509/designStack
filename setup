#!/usr/bin/env bash
# designStack setup вҖ” installs designStack skills into Claude Code
set -e

DESIGNSTACK_DIR="$HOME/.claude/skills/ds"
DESIGNSTACK_VER=$(cat "$DESIGNSTACK_DIR/VERSION" 2>/dev/null || echo "0.1.0")
_QUIET="no"
_PREFIX="namespaced"

# в”Җв”Җ Flag parsing в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
for arg in "$@"; do
  [ "$arg" = "--quiet" ] || [ "$arg" = "-q" ] && _QUIET="yes"
  [ "$arg" = "--flat" ] && _PREFIX="flat"
done

log() { [ "$_QUIET" = "no" ] && echo "$@"; }

# в”Җв”Җ OS check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_OS=$(uname -s 2>/dev/null || echo "unknown")
if [ "$_OS" != "Darwin" ] && [ "$_OS" != "Linux" ]; then
  echo "  designStack requires Mac or Linux."
  echo "  Windows support via WSL вҖ” see docs/windows.md for a step-by-step guide."
  echo ""
  exit 1
fi

log ""
log "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—"
log "  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қ"
log "  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ "
log "  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— "
log "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—"
log "  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ"
log ""
log "  v$DESIGNSTACK_VER вҖ” Claude Code for designers"
log ""

# в”Җв”Җ Check Claude Code is installed в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if ! command -v claude >/dev/null 2>&1; then
  echo "  вң— Claude Code not found."
  echo "    Install it from: https://claude.ai/download"
  echo ""
  exit 1
fi
log "  вң“ Claude Code found"

# в”Җв”Җ Version migration в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
_INSTALLED_VER_FILE="$DESIGNSTACK_DIR/.installed-version"
_PREV_VER=""
[ -f "$_INSTALLED_VER_FILE" ] && _PREV_VER=$(cat "$_INSTALLED_VER_FILE")
echo "$DESIGNSTACK_VER" > "$_INSTALLED_VER_FILE"
if [ -n "$_PREV_VER" ] && [ "$_PREV_VER" != "$DESIGNSTACK_VER" ]; then
  log "  вң“ Upgraded from v$_PREV_VER вҶ’ v$DESIGNSTACK_VER"
fi

# в”Җв”Җ Check for gstack browse binary (optional, enables visual features) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ -x "$HOME/.claude/skills/gstack/browse/dist/browse" ]; then
  log "  вң“ gstack found вҖ” visual features enabled"
else
  log "  вҡ   gstack not found вҖ” /look, /mobile, /a11y, and /unstuck will describe"
  log "     issues in plain English instead of showing screenshots."
  log "     Install gstack for full visual features: https://github.com/garrytan/gstack"
fi

# в”Җв”Җ Flat mode: create symlinks without /ds: prefix в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ "$_PREFIX" = "flat" ]; then
  _SKILLS_DIR="$HOME/.claude/skills"
  for skill in start context plain unstuck look mobile a11y save share; do
    _TARGET="$DESIGNSTACK_DIR/$skill/SKILL.md"
    _LINK_DIR="$_SKILLS_DIR/$skill"
    if [ -d "$_TARGET" ] || [ -f "$_TARGET" ]; then
      mkdir -p "$_LINK_DIR"
      ln -sf "$_TARGET" "$_LINK_DIR/SKILL.md" 2>/dev/null || true
    fi
  done
  log "  вң“ Flat mode: skills available as /start, /context, /plain, /unstuck, etc."
fi

# в”Җв”Җ Add designStack to global CLAUDE.md в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
GLOBAL_CLAUDE="$HOME/.claude/CLAUDE.md"

if [ -f "$GLOBAL_CLAUDE" ] && grep -q "dstack:start" "$GLOBAL_CLAUDE" 2>/dev/null; then
  log "  вң“ designStack already in global CLAUDE.md"
else
  cat >> "$GLOBAL_CLAUDE" << 'EOF'

# designStack
- **designStack** is installed. Use designStack skills for design rules, visual QA, accessibility, and error recovery.
- `/ds:start` вҖ” First session wizard. Run this once per project.
- `/ds:context` вҖ” Refresh your Design Bible when your brand changes.
- `/ds:plain` вҖ” Translate any Claude plan into plain English before you accept it.
- `/ds:unstuck` вҖ” Something broke. Get a plain-English diagnosis.
- `/ds:look` вҖ” Does it look right? Visual check against your brand rules.
- `/ds:mobile` вҖ” Check it on phone, tablet, and desktop.
- `/ds:a11y` вҖ” Accessibility grade AвҖ“D with every problem marked.
- `/ds:save` вҖ” Save your progress with a human-readable description.
- `/ds:share` вҖ” Deploy and get a shareable link.
EOF
  log "  вң“ Added designStack to global CLAUDE.md"
fi

# в”Җв”Җ Done в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
log ""
log "  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
log "  в”Ӯ  designStack v$DESIGNSTACK_VER installed!                                    в”Ӯ"
log "  в”Ӯ                                                             в”Ӯ"
log "  в”Ӯ  Open Claude Code and type:                                 в”Ӯ"
log "  в”Ӯ                                                             в”Ӯ"
log "  в”Ӯ    /ds:start                                            в”Ӯ"
log "  в”Ӯ                                                             в”Ӯ"
log "  в”Ӯ  That's it. The wizard takes 5 minutes and sets everything  в”Ӯ"
log "  в”Ӯ  up. Every other skill works automatically after that.      в”Ӯ"
log "  в”Ӯ                                                             в”Ӯ"
log "  в”Ӯ  All commands:                                              в”Ӯ"
log "  в”Ӯ    /ds:start     First-session setup wizard             в”Ӯ"
log "  в”Ӯ    /ds:context   Refresh your Design Bible              в”Ӯ"
log "  в”Ӯ    /ds:plain     Translate plans to plain English        в”Ӯ"
log "  в”Ӯ    /ds:unstuck   Debug broken things                    в”Ӯ"
log "  в”Ӯ    /ds:look      Visual check against brand rules       в”Ӯ"
log "  в”Ӯ    /ds:mobile    Phone + tablet + desktop side-by-side  в”Ӯ"
log "  в”Ӯ    /ds:a11y      Accessibility grade with problem map   в”Ӯ"
log "  в”Ӯ    /ds:save      Save progress with a description       в”Ӯ"
log "  в”Ӯ    /ds:share     Deploy and get a shareable link        в”Ӯ"
log "  в”Ӯ                                                             в”Ӯ"
log "  в”Ӯ  Questions? https://github.com/harshii0509/designStack/discussions в”Ӯ"
log "  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
log ""
