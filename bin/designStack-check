#!/usr/bin/env bash
# designStack-check — health check for designStack installation
DESIGNSTACK_DIR="$HOME/.claude/skills/ds"
DESIGNSTACK_VER=$(cat "$DESIGNSTACK_DIR/VERSION" 2>/dev/null || echo "unknown")

echo "designStack v$DESIGNSTACK_VER"
echo ""

# Browse binary
if [ -x "$DESIGNSTACK_DIR/browse/dist/browse" ]; then
  echo "✓ Browse: found — visual features enabled"
else
  echo "⚠ Browse: not found — visual skills will use text descriptions"
fi

# Claude Code
if command -v claude >/dev/null 2>&1; then
  echo "✓ Claude Code: found"
else
  echo "✗ Claude Code: not found"
fi

# Git
if command -v git >/dev/null 2>&1; then
  echo "✓ Git: found"
else
  echo "✗ Git: not found — /save won't work"
fi

# Design Bible (project-specific, check CWD)
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
if [ -f "$ROOT/design/DESIGN-BIBLE.md" ]; then
  echo "✓ Design Bible: found at design/DESIGN-BIBLE.md"
elif [ -f "$ROOT/DesignBrain.md" ]; then
  echo "✓ Design Bible: DesignBrain.md found (compatible)"
elif [ -f "$ROOT/DESIGN.md" ]; then
  echo "✓ Design Bible: DESIGN.md found (will extend)"
else
  echo "⚠ Design Bible: not set up for this project"
  echo "  Fix: run /ds:context"
fi

echo ""
