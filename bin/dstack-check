#!/usr/bin/env bash
# dstack-check — health check for dStack installation
DSTACK_DIR="$HOME/.claude/skills/dstack"
DSTACK_VER=$(cat "$DSTACK_DIR/VERSION" 2>/dev/null || echo "unknown")

echo "dStack v$DSTACK_VER"
echo ""

# Browse binary
if [ -x "$HOME/.claude/skills/gstack/browse/dist/browse" ]; then
  echo "✓ Browse: gstack browse found — visual features enabled"
elif [ -x "$DSTACK_DIR/browse/dist/browse" ]; then
  echo "✓ Browse: dstack browse found"
else
  echo "⚠ Browse: not found — visual skills will use text descriptions"
  echo "  Fix: install gstack → https://github.com/garrytan/gstack"
fi

# Claude Code
if command -v claude >/dev/null 2>&1; then
  echo "✓ Claude Code: found"
else
  echo "✗ Claude Code: not found"
fi

# Git
if command -v git >/dev/null 2>&1; then
  echo "✓ Git: found"
else
  echo "✗ Git: not found — /save won't work"
fi

# Design Bible (project-specific, check CWD)
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo ".")
if [ -f "$ROOT/dstack/DESIGN-BIBLE.md" ]; then
  echo "✓ Design Bible: found at dstack/DESIGN-BIBLE.md"
elif [ -f "$ROOT/DesignBrain.md" ]; then
  echo "✓ Design Bible: DesignBrain.md found (compatible)"
elif [ -f "$ROOT/DESIGN.md" ]; then
  echo "✓ Design Bible: DESIGN.md found (will extend)"
else
  echo "⚠ Design Bible: not set up for this project"
  echo "  Fix: run /dstack:context"
fi

echo ""
